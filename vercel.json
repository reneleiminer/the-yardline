{
  "crons": [
    {
      "path": "/api/push/check?reason=cron_today_games",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/push/check?reason=cron_weekly_streaks",
      "schedule": "0 21 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
